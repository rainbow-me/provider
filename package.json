{
  "name": "@rainbow-me/provider",
  "version": "0.2.0",
  "engines": {
    "node": ">=22.17.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./defaults": {
      "types": "./dist/defaults/index.d.ts",
      "default": "./dist/defaults/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    }
  },
  "scripts": {
    "prepack": "yarn build",
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint --cache --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "yarn release:verify-git && yarn build && changeset publish --tag latest",
    "release:verify-git": "git diff --exit-code && git rev-parse --abbrev-ref HEAD | grep \"main\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@typescript-eslint/eslint-plugin": "6.20.0",
    "@typescript-eslint/parser": "6.20.0",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "jsdom": "24.0.0",
    "prettier": "3.2.4",
    "typescript": "5.4.5",
    "vitest": "1.6.1",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "ox": "^0.6.7"
  },
  "peerDependencies": {
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.2.2"
}
